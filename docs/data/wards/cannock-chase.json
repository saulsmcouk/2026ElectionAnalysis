ia/images/people/110035/8cc36961-fe5e-4be2-bdb5-7a626df82d67.png"},{"n":"Ron Turville","p":"Independent","v":48,"r":5,"e":false,"g":"male","m":"existing","cf":"high","pid":"2280","img":"https://candidates.democracyclub.org.uk/media/images/people/2280/6fec8aa9-3e2f-4dd5-8ab2-f0390d5a9a9a.png"}]},{"ward":"Hednesford Hills & Rawnsley","seats":1,"turnout_pct":43.35,"results_url":"https://www.cannockchasedc.gov.uk/council/elections-voting/elections/election-results/cannock-chase-district-council-elections-7-may","candidates":[{"n":"Rhys Anthony Mandry","p":"Reform UK","v":1293,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"high","pid":"122117","img":"https://candidates.democracyclub.org.uk/media/images/people/122117/c1a5aece-43ef-42c9-adee-8de6cda8a6b0.png"},{"n":"Rachel Lauren Rock","p":"Green Party","v":837,"r":2,"e":false,"g":"female","m":"existing","cf":"high","pid":"110049","img":"https://candidates.democracyclub.org.uk/media/images/people/110049/6aeb3517-fb90-4995-a27e-712ec67cdbb6.png","stmt":"Rachel grew up in Cannock and has lived in Hednesford for the past ten years. She has worked as a Local Authority Officer for over 20 years within the West Midlands in various roles within Social Housing, Highways and Transportation Infrastructure.\n\nRachel said “I feel incredibly lucky to live here with Cannock Chase on my doorstep. I am encouraged by the sense of community which has been built over the years here in Hednesford and the surrounding villages. I want to help tackle the issues which matter most to the community and be actively involved in shaping a greener, cleaner, fairer Hednesford Hills and Rawnsley for everyone.”"},{"n":"Ron Sutton","p":"Conservative and Unionist Party","v":350,"r":3,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"131951"},{"n":"Alan Raymond Pearson","p":"Labour Party","v":154,"r":4,"e":false,"g":"male","m":"existing","cf":"high","pid":"10123","img":"https://candidates.democracyclub.org.uk/media/images/images/10123-31c32e5e-0317-4075-9634-a8c08923322c.png"}]},{"ward":"Hednesford Pye Green","seats":2,"turnout_pct":37.04,"results_url":"https://www.cannockchasedc.gov.uk/council/elections-voting/elections/election-results/cannock-chase-district-council-elections-7-may","candidates":[{"n":"Robert Arron Branson","p":"Reform UK","v":1165,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"high","pid":"131955"},{"n":"Graham Terence Millington","p":"Reform UK","v":1152,"r":2,"e":true,"g":"male","m":"gender_guesser","cf":"high","pid":"131982"},{"n":"Angela Rose Rushton","p":"Green Party","v":511,"r":3,"e":false,"g":"female","m":"existing","cf":"high","pid":"126770","img":"https://candidates.democracyclub.org.uk/media/images/people/126770/220c37a5-d755-47b8-a966-4ed531af4052.png","stmt":"“I’ve lived and worked in Cannock and Hednesford all my life, and I’ve always taken pride in giving back to our community. Whether you know me from toddler groups or local SEND initiatives, you’ll know I’m passionate about making a difference for young families and being a voice for those who feel they haven’t got one. I’m here to listen, to act, and to fight for the issues that matter most to you — because your voice deserves to be heard.”"},{"n":"Cameron John Rushton","p":"Green Party","v":487,"r":4,"e":false,"g":"male","m":"existing","cf":"high","pid":"126743","img":"https://candidates.democracyclub.org.uk/media/images/people/126743/f85fe8c8-2380-4488-8bbe-48b34c4fec63.png","stmt":"“I’m an independent voice to represent the 99% of my community, not the 1%. I’m eager to hear from you and give our home some hope.”\n\nCameron is interested in protecting our local environment, supporting our public services and representing Hednesford and Cannock Chase’s communities."},{"n":"Hyra Sutton","p":"Conservative and Unionist Party","v":262,"r":5,"e":false,"g":"female","m":"claude","cf":"high","pid":"39113","img":"https://candidates.democracyclub.org.uk/media/images/people/39113/28089233-10d3-4164-9196-0e0bbbbd2d38.png"},{"n":"Sheila Margaret Cartwright","p":"Labour Party","v":245,"r":6,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"39154"},{"n":"Paula Lilian Stanton","p":"Labour Party","v":212,"r":7,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"78180","img":"https://candidates.democracyclub.org.uk/media/images/people/78180/505bb04c-eefe-4015-a115-841fe5e5e5ac.png","stmt":"It's time to deliver a better deal for the residents of Hednesford North. Labour's plan is to make Cannock Chase one of the best places to live, work, visit and do business in the West Midlands by raising skill levels of our local workforce, bring in more higher paid jobs to kick-start our economy and invest in our communities. We will work for you by fighting to save local services and protect our heritage. Be part of the fight back - Vote Labour Vote Paula STANTON. Thank you."},{"n":"Sharon Denise Jagger","p":"Independent","v":119,"r":8,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"79279","img":"https://candidates.democracyclub.org.uk/media/images/people/79279/9af96a8a-9ab9-45ba-976f-7153cb1bb609.png"}]},{"ward":"Norton Canes","seats":1,"turnout_pct":37.47,"results_url":"https://www.cannockchasedc.gov.uk/council/elections-voting/elections/election-results/cannock-chase-district-council-elections-7-may","candidates":[{"n":"Georgina Ellen Jeffery","p":"Reform UK","v":1515,"r":1,"e":true,"g":"female","m":"gender_guesser","cf":"high","pid":"131985","img":"https://candidates.democracyclub.org.uk/media/images/people/131985/d04bb9d1-778e-4e5f-9103-55886197167e.png"},{"n":"Jean Hill","p":"Labour Party","v":406,"r":2,"e":false,"g":"female","m":"gender_guesser","cf":"low","pid":"110056","img":"https://candidates.democracyclub.org.uk/media/images/people/110056/4fd68943-e0f8-4d14-a1da-20b8d18a4707.png"},{"n":"Wendy Yates","p":"Conservative and Unionist Party","v":386,"r":3,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"39156"},{"n":"Linda Joy Mawle","p":