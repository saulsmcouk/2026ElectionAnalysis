wn_count":0,"inc_total":0,"inc_elected":0,"inc_defeated":0,"new_elected":1},{"ward":"Pittville","seats":1,"turnout_pct":50.88,"results_url":"https://democracy.cheltenham.gov.uk/mgElectionAreaResults.aspx?ID=145&RPID=176147037","candidates":[{"n":"Cecily Frances Grace Henderson","p":"Liberal Democrats","v":1037,"r":1,"e":true,"g":"female","m":"gender_guesser","cf":"high","pid":"127114","img":"https://candidates.democracyclub.org.uk/media/images/people/127114/5419e0e9-d254-4796-a210-10c8d1e139e1.png"},{"n":"Jamal Rahman","p":"Green Party","v":470,"r":2,"e":false,"g":"male","m":"existing","cf":"high","pid":"125527","img":"https://candidates.democracyclub.org.uk/media/images/people/125527/7df3ec10-c3b6-4494-83ab-6331449c4566.png","stmt":"1. Improve local services and the reopening of the HRC\n2. Conserving our beautiful nature \n3. Empowering and platforming the youth","bd":"2003"},{"n":"Ashley John Fraser Mills","p":"Reform UK","v":389,"r":3,"e":false,"g":"female","m":"gender_guesser","cf":"low","pid":"127120"},{"n":"Alan James Davis","p":"Conservative and Unionist Party","v":362,"r":4,"e":false,"g":"male","m":"existing","cf":"high","pid":"77356"},{"n":"Martin William Glozier","p":"Labour Party","v":45,"r":5,"e":false,"g":"male","m":"existing","cf":"high","pid":"110377","img":"https://candidates.democracyclub.org.uk/media/images/people/110377/7dc9b85d-959a-4be4-8b5e-c163e70d7fea.png"}],"female_count":2,"male_count":3,"unknown_count":0,"inc_total":0,"inc_elected":0,"inc_defeated":0,"new_elected":1},{"ward":"Prestbury","seats":1,"turnout_pct":53.75,"results_url":"https://democracy.cheltenham.gov.uk/mgElectionAreaResults.aspx?ID=146&RPID=176062183","candidates":[{"n":"Jan Foster","p":"Green Party","v":993,"r":1,"e":true,"g":"female","m":"existing","cf":"high","inc":true,"pid":"108909","img":"https://candidates.democracyclub.org.uk/media/images/people/108909/07b2ae67-61cd-430c-bf05-d8d3ce8ad608.png","stmt":"I’ve been based locally for more than twenty years, but during that time I’ve had a couple of spells working in Africa and Asia, after which I decided to join the Green Party. I saw  people struggling at the sharp end of climate change and  plastic pollution. Communities with very little municipal infrastructure were  having to cope with tides of litter (that they didn’t produce), floods, damaged  roads and food insecurity. \n\nThis really brought home to me how our Borough Council here in Cheltenham seems unable to get on top of challenges such as  waste disposal, water management, transport and road safety. I am standing for  the Borough Council as a Green Party candidate because this is the only party,  locally and nationally, who are taking such issues seriously."},{"n":"Lance Alan Fletcher","p":"Reform UK","v":621,"r":2,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"127129","img":"https://candidates.democracyclub.org.uk/media/images/people/127129/122400cd-427f-4a76-8022-245c20e78b24.png"},{"n":"Chris Mason","p":"Conservative and Unionist Party","v":430,"r":3,"e":false,"g":"male","m":"existing","cf":"high","pid":"127143","img":"https://candidates.democracyclub.org.uk/media/images/people/127143/11f4a80c-68e5-478a-9c16-89b8bcde2dab.png"},{"n":"Ben Ingram","p":"Liberal Democrats","v":364,"r":4,"e":false,"g":"male","m":"existing","cf":"high","pid":"88011","img":"https://candidates.democracyclub.org.uk/media/images/people/88011/ad871c76-259e-4bfb-bd9c-3238121db5e8.png"}],"female_count":1,"male_count":3,"unknown_count":0,"inc_total":1,"inc_elected":1,"inc_defeated":0,"new_elected":0},{"ward":"Springbank","seats":1,"turnout_pct":34.98,"results_url":"https://democracy.cheltenham.gov.uk/mgElectionAreaResults.aspx?ID=147&RPID=176151670","candidates":[{"n":"Peter Jeremy Jeffries","p":"Liberal Democrats","v":719,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"high","inc":true,"pid":"46699","img":"https://candidates.democracyclub.org.uk/media/images/people/46699/2c26a02f-b36d-4d8b-9726-2874dc2a2097.png","tw":"\"PeterJeffries3\""},{"n":"Haydn Douglas Pearl","p":"Reform UK","v":498,"r":2,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"67136","img":"https://candidates.democracyclub.org.uk/media/images/people/67136/89a69c73-7ac9-4c51-a84a-706a88a0e272.png"},{"n":"Sarp Cetin","p":"Green Party","v":195,"r":3,"e":false,"g":"male","m":"claude","cf":"high","pid":"125533"},{"n":"Helen Frances Shill","p":"Conservative and Unionist Party","v":162,"r":4,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"110349","img":"https://candidates.democracyclub.org.uk/media/images/people/110349/f880ea4f-30d5-4cbf-a25d-5354fab39c17.png"},{"n":"David Nigel Edgar","p":"Christian Peoples Alliance","v":22,"r":5,"e":false,"g":"male","m":"existing","cf":"high","pid":"117056","img":"https://candidates.democracyclub.org.uk/media/images/people/117056/568dace0-9ba5-4d76-aa02-178152cd2ab2.png"}],"female_count":1,"male_count":4,"unknown_count":0,"inc_total":1,"inc_elected":1,"inc_defeated":0,"new_elected":0},{"ward":"St Mark's","seats":1,"turnout_pct":39.05,"results_url":"https://democracy.cheltenham.gov.uk/mgElectionElectionAreaResults.aspx?Page=all&EID=24","candidates":[{"n":"Richard James Pineger","p":"Liberal Democrats","v":752,"r":1,"e":true,"g":"male","m":"existing","cf":"high","inc":true,"pid":"73623","img":"https://candidates.democracyclub.org.uk/media/images/images/73623-8a78a36f-7d00-4698-9e70-90ae9573c911.png"},{"n":"Antony Neil Fillingham","p":"Reform UK","v":438,"r":2,"e":false,"g":"male","m":"existing","cf":"high","pid":"127199"},{"n":"Kieran Scott","p":"Green Party","v":297,"r":3,"e":false,"g":"male","m":"existing","cf":"high","pid":"127184","img":"https://candidates.democracyclub.org.uk/media/images/people/127184/e7fb72bb-3c81-46e3-bcd8-85077fe050b4.png"},{"n":"Colin John Parsons","p":"Conservative and Unionist Party","v":160,"r":4,"e":false,"g":"male","m":"existing","cf":"high","pid":"109618","img":"https://candidates.democracyclub.org.uk/media/images/people/127207/8b151bfa-9aab-4893-bea0-0ea2765705a9.png"},{"n":"Julie Frances Farmer","p":"Labour Party","v":67,"r":5,"e":false,"g":"female","m":"existing","cf":"high","pid":"77352","img":"https://candidates.democracyclub.org.uk/media/images/people/77352/e8f0d9cd-24ab-4009-a149-b8348c2c369c.png","stmt":"I have lived very happily in St Mark’s for 25 years.  My career focussed on adult and vocational education and widening participation.\nIf elected I would use my position to demand \n•\tbetter social and educational services for adults in Gloucestershire\n•\ta lasting improvement in the way our schools are managed and resourced\n•\timprovements in the quality of life for all residents of St Mark’s  and St Peter’s\n•\topen and transparent management of all the county services and finances"}],"female_count":1,"male_count":4,"unknown_count":0,"inc_total":1,"inc_elected":1,"inc_defeated":0,"new_elected":0},{"ward":"St Paul's","seats":1,"turnout_pct":33.49,"results_url":"https://democracy.cheltenham.gov.uk/mgElectionAreaResults.aspx?ID=149&RPID=176154151","candidates":[{"n":"Ashleigh Davies","p":"Green Party","v":723,"r":1,"e":true,"g":"female","m":"gender_guesser","cf":"high","inc":true,"pid":"110391","img":"https://candidates.democracyclub.org.uk/media/images/people/110391/9414a3ef-2615-4369-967d-b5e398464777.png","stmt":"My name is Ashleigh Davies and I’m standing to be your Green Party councillor in St Paul's.\n\nI am honoured to have been selected as your Green candidate for St Paul's, and together with your existing hard working Green councillor in St Paul's Tabi Joy I will do my absolute best to represent you on the council! St Paul's is definitely a place in Cheltenham where you can vote Green and get Green - and having seen how the Lib Dems focus on out of town projects I know we need more representation on the council for our area.\n\nI live close to the big Tesco in St Paul's, and work as a mechanical engineer. I have been working closely with Tabi on Green campaigns in St Paul's, especially road safety and speeding which have gone on unchecked for too long.\n\nI’m standing to be a councillor to make a difference, and represent my community! Cheltenham has been run by the Lib Dems unchallenged for almost 15 years now, it is time for change and new thinking. The more Greens we elect the more we can hold the council to account, pushing for the change we so desperately need.\n\nIf you want to raise anything with me regarding St Paul's you can contact me at ashleigh.davies@cheltenham.greenparty.org.uk"},{"n":"Cathal Lynch","p":"Liberal Democrats","v":374,"r":2,"e":false,"g":"male","m":"claude","cf":"high","pid":"110361","img":"https://candidates.democracyclub.org.uk/media/images/people/110361/3b1ee301-94ad-4a99-8c6b-589338a7e5d7.png"},{"n":"Steve Buckley","p":"Reform UK","v":208,"r":3,"e":false,"g":"male","m":"existing","cf":"high","pid":"127217"},{"n":"Sandra Gloria Parsons","p":"Conservative and Unionist Party","v":87,"r":4,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"109619","img":"https://candidates.democracyclub.org.uk/media/images/people/109619/95019036-6743-4142-863e-dd5a0aee7027.png"},{"n":"Christopher John Meehan","p":"Labour Party","v":40,"r":5,"e":false,"g":"male","m":"existing","cf":"high","pid":"42056","img":"https://candidates.democracyclub.org.uk/media/images/people/42056/8c77c9d7-831a-4ee1-bc7c-b34a6035ac41.png"}],"female_count":2,"male_count":3,"unknown_count":0,"inc_total":1,"inc_elected":1,"inc_defeated":0,"new_elected":0},{"ward":"St Peter's","seats":1,"turnout_pct":42.33,"results_url":"https://democracy.cheltenham.gov.uk/mgElectionAreaResults.aspx?ID=150&RPID=176123364","candidates":[{"n":"Cathy Dearden","p":"Liberal Democrats","v":876,"r":1,"e":true,"g":"female","m":"existing","cf":"high","pid":"127241","img":"https://candidates.democracyclub.org.uk/media/images/people/127241/ef56550a-872e-4fb3-9fc3-5234631d5c00.png"},{"n":"John Jarvis","p":"Green Party","v":444,"r":2,"e":false,"g":"male","m":"existing","cf":"high","pid":"125535","img":"https://candidates.democracyclub.org.uk/media/images/people/125535/9899b700-b4a6-49f4-aa4f-a9c4fb8c7eb4.png"},{"n":"Anthony William Green","p":"Reform UK","v":386,"r":3,"e":false,"g":"male","m":"existing","cf":"high","pid":"127242"},{"n":"Risha Santilal","p":"Conservative and Unionist Party","v":187,"r":4,"e":false,"g":"female","m":"claude","cf":"high","pid":"127250","img":"https://candidates.democracyclub.org.uk/media/images/people/127250/1a95b8f2-156a-4e1c-aa55-6c0fb7a7c3ac.png"},{"n":"Michael Thomas Farmer","p":"Labour Party","v":72,"r":5,"e":false,"g":"male","m":"existing","cf":"high","pid":"77357","img":"https://candidates.democracyclub.org.uk/media/images/people/77357/6e89e54c-c26b-4e03-9c22-ac5f4d78ca49.png","stmt":"I’m a long-term resident of Gloucestershire with a particular interest in education and training.  If elected I would:\n•\tRepresent the interests of all residents of Prestbury and Swindon Village without fear or favour\n•\tPress for more openness and honesty at Shire Hall\n•\tWork to protect the most vulnerable in our society\n•\tPush for improvements in all services provided by the County Council."},{"n":"Billy Jones","p":"Trade Unionist and Socialist Coalition","v":6,"r":6,"e":false,"g":"male","m":"existing","cf":"high","pid":"119251","img":"https://candidates.democracyclub.org.uk/media/images/people/119251/efea0ebe-5556-4050-9e7c-700478f9cca8.png"}],"female_count":2,"male_count":4,"unknown_count":0,"inc_total":0,"inc_elected":0,"inc_defeated":0,"new_elected":1},{"ward":"Swindon Village","seats":1,"turnout_pct":44.17,"results_url":"https://democracy.cheltenham.gov.uk/mgElectionAreaResults.aspx?ID=151&RPID=176139366","candidates":[{"n":"Richard Lawler","p":"Liberal Democrats","v":606,"r":1,"e":true,"g":"male","m":"existing","cf":"high","pid":"120358","img":"https://candidates.democracyclub.org.uk/media/images/people/120358/a4fb575d-9ab1-4541-9034-3b9274d2d109.png"},{"n":"Matthew David William Podmore","p":"Reform UK","v":462,"r":2,"e":false,"g":"male","m":"existing","cf":"high","pid":"120294","img":"https://candidates.democracyclub.org.uk/media/images/people/120294/dd80a865-4a45-482b-9d64-c9ea16569f44.png"},{"n":"Ian Cameron","p":"Green Party","v":363,"r":3,"e":false,"g":"male","m":"existing","cf":"high","pid":"95507","img":"https://candidates.democracyclub.org.uk/media/images/people/125536/73a68169-4b75-4cb8-9eec-22c6dd0b79c2.png","stmt":"My name is Ian Cameron and I am proud to be your Green Party candidate for Prestbury alongside Jan Foster.\n\nI have lived just south of Prestbury for over ten years with my wife and 3 children, we work in the area, our kids go to nearby local schools, and we have seen first hand the issues that persist in our community after decades of \"more of the same\" by the Conservatives and Liberal Democrats - it's time for change!\n\nOn the doorstep people are telling me the Lib Dem Council and the Conservative government are out of touch. People feel their votes are being taken for granted. I live locally, and I’m listening to local residents.\n\nAs your councillor, your priorities will be my priorities.\n\n✔ Fighting against bad development, like Oakley Farm\n\n✔ Protecting our natural heritage and environment\n\n✔ Rural public transport, and improving the state of roads and pavements.\n\nDo you have an issue you think should be on this list? Let me know by getting in touch."},{"n":"Edward Wadih Hazzan","p":"Conservative and Unionist Party","v":126,"r":4,"e":false,"g":"male","m":"existing","cf":"high","pid":"42065","img":"https://candidates.democracyclub.org.uk/media/images/people/42065/27625906-a462-4c0c-ae48-17c7f81ccfb8.png"},{"n":"Chris Johnson","p":"Labour Party","v":45,"r":5,"e":false,"g":"male","m":"existing","cf":"high","pid":"126889","img":"https://candidates.democracyclub.org.uk/media/images/people/126889/d6cb250a-272e-448e-bb77-6f7228fdeab4.png"}],"female_count":0,"male_count":5,"unknown_count":0,"inc_total":0,"inc_elected":0,"inc_defeated":0,"new_elected":1},{"ward":"Up Hatherley","seats":1,"turnout_pct":49.41,"results_url":"https://democracy.cheltenham.gov.uk/mgElectionAreaResults.aspx?XXR=0&ID=152&RPID=176053274","candidates":[{"n":"Julie Margaret Sankey","p":"Liberal Democrats","v":1177,"r":1,"e":true,"g":"female","m":"gender_guesser","cf":"high","pid":"77376","img":"https://candidates.democracyclub.org.uk/media/images/people/77376/458827ac-df86-4eca-a0f6-ff5e61ec6273.png"},{"n":"Tristram John Francis Torrance","p":"Reform UK","v":456,"r":2,"e":false,"g":"male","m":"existing","cf":"high","pid":"127264"},{"n":"Joshua James Godfrey","p":"Conservative and Unionist Party","v":431,"r":3,"e":false,"g":"male","m":"existing","cf":"high","pid":"125453","img":"https://candidates.democracyclub.org.uk/media/images/people/125453/8e28f8a6-eaa6-4118-9cc8-62902d4ccebe.png","stmt":"With family roots in Cheltenham, I care deeply about our town. My great grandad was a teacher here and my grandparents met here too, so Cheltenham has always been a special place to me.\n\nAfter 16 years of Lib Dem majority rule, ask yourself this. Is Cheltenham reaching its full potential?\n\nI'm standing in these local elections because I want better for Up Hatherley and Cheltenham. If I'm given the honour of being elected as your Councillor on May 7th, I will hold the Lib Dem administration to account, fight to protect our greenbelt from overdevelopment and fight for the infrastructure investment that residents need and deserve.","bd":"1994"},{"n":"Elizabeth Johnson","p":"Green Party","v":234,"r":4,"e":false,"g":"female","m":"existing","cf":"high","pid":"125537"}],"female_count":2,"male_count":2,"unknown_count":0,"inc_total":0,"inc_elected":0,"inc_defeated":0,"new_elected":1},{"ward":"Warden Hill","seats":1,"turnout_pct":51.68,"results_url":"https://democracy.cheltenham.gov.uk/mgElectionAreaResults.aspx?ID=153&RPID=176056901","candidates":[{"n":"Tony Oliver","p":"Liberal Democrats","v":1094,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"low","inc":true,"pid":"15243","img":"https://candidates.democracyclub.org.uk/media/images/people/15243/577cc28a-88a7-4b15-a7be-c19640486b63.png"},{"n":"David Paul Dodwell","p":"Reform UK","v":441,"r":2,"e":false,"g":"male","m":"existing","cf":"high","pid":"127276"},{"n":"Georgie Bass","p":"Conservative and Unionist Party","v":360,"r":3,"e":false,"g":"female","m":"existing","cf":"high","pid":"127270","img":"https://candidates.democracyclub.org.uk/media/images/people/127270/d4503785-fccc-4f47-af57-d18a46d20aae.png"},{"n":"Sarah Quekett","p":"Green Party","v":177,"r":4,"e":false,"g":"female","m":"existing","cf":"high","pid":"110378"},{"n":"Ned Holt","p":"Labour Party","v":27,"r":5,"e":false,"g":"male","m":"existing","cf":"high","pid":"127283"}],"female_count":2,"male_count":3,"unknown_count":0,"inc_total":1,"inc_elected":1,"inc_defeated":0,"new_elected":0}]}