acyclub.org.uk/media/images/people/129734/59a695b3-fbba-410d-bb95-d59e4fadba6e.png"},{"n":"Alicia Claire Marland","p":"Liberal Democrats","v":1636,"r":2,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"87413","img":"https://candidates.democracyclub.org.uk/media/images/people/87413/b7dd8386-4c13-4a17-9928-f3b530c7b4da.png"},{"n":"Dave Barter","p":"Labour Party","v":279,"r":3,"e":false,"g":"male","m":"existing","cf":"high","pid":"98402","img":"https://candidates.democracyclub.org.uk/media/images/people/98402/6c21a0d1-1671-42b2-ac27-19024cd7209e.png"},{"n":"Joe Bardsley","p":"Green Party","v":238,"r":4,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"129731","img":"https://candidates.democracyclub.org.uk/media/images/people/129731/89ec751c-6ea8-4767-80c4-be022c9cb34a.png"},{"n":"Lisa Hartington","p":"Conservative and Unionist Party","v":143,"r":5,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"129733","img":"https://candidates.democracyclub.org.uk/media/images/people/129733/8afe134a-fa49-4f19-a251-55ebe6c27f65.png"}]},{"ward":"Shaw","seats":1,"turnout_pct":47.11,"results_url":"https://www.oldham.gov.uk/election_results_may7_2026","candidates":[{"n":"Steve Eyre","p":"Reform UK","v":1555,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"high","pid":"129634","img":"https://candidates.democracyclub.org.uk/media/images/people/129634/1e87ea8b-5ce8-495c-bf1b-29ee0599f2cd.png"},{"n":"Tom Penketh","p":"Liberal Democrats","v":955,"r":2,"e":false,"g":"male","m":"existing","cf":"high","pid":"97684","img":"https://candidates.democracyclub.org.uk/media/images/people/97684/58557e79-c8be-474c-9728-262b5dbab828.png","stmt":"A FAIR DEAL FOR SHAW\nWe need action on pot holes,\nweeds, gullies/grids/flooding, fly-tipping, litter\nand dog fouling. We are also holding the\nLabour-backing ”Independents” to account.\n\nA NEW HEALTH CENTRE\nWe got the services you need, where you\nneed them – here!\n\nPROTECT OUR GREEN BELT\nOpposing Labour's plans to weaken green\nbelt protection, and fighting for improved\nroads, healthcare and schools.\n\nSTOP THE ETON MESS\nDon’t waste our money on a sixth form\ncollege we don’t need.\n\nCAMPAIGNING FOR A NEW LEISURE HUB\nWe want to expand around the new health\ncentre to create a dedicated hub that will\nbring health and leisure services together in one\nplace for local residents.\n\nINVESTING IN OUR AREA\nWe proposed an extra £2.5 million in grant\nfunding for local communities rather than\nLabour's plans for more spending in Oldham town\ncentre, putting spending decisions in your hands.","bd":"2005"},{"n":"Hamid Ali","p":"Labour Party","v":336,"r":3,"e":false,"g":"male","m":"claude","cf":"high","pid":"129633"},{"n":"Ben Jack Ingham","p":"Green Party","v":253,"r":4,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"129636","img":"https://candidates.democracyclub.org.uk/media/images/people/129636/ade72cff-9f84-43d4-9eaf-0cc41a4abd30.png"},{"n":"Sarah Howarth","p":"Independent","v":177,"r":5,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"129635"},{"n":"Lee Navesey","p":"Independent","v":175,"r":6,"e":false,"g":"male","m":"gender_guesser","cf":"low","pid":"98373","img":"https://candidates.democracyclub.org.uk/media/images/people/98373/34e4e53d-94a2-41b9-b648-d1ae7061b1f5.png"},{"n":"Adi Kohli","p":"Conservative and Unionist Party","v":53,"r":7,"e":false,"g":"male","m":"claude","cf":"medium","pid":"129637"}]},{"ward":"St James'","seats":1,"turnout_pct":39.51,"results_url":"https://www.oldham.gov.uk/election_results_may7_2026","candidates":[{"n":"Gary Tarbuck","p":"Reform UK","v":1938,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"high","pid":"73165","img":"https://candidates.democracyclub.org.uk/media/images/people/129738/11d7ffbb-eaa3-45a2-9c88-d284901b7279.png","tw":"\"TarbuckOf\""},{"n":"Angela Carol Cosgrove","p":"Labour Party","v":576,"r":2,"e":false,"g":"female","m":"existing","cf":"high","pid":"51195","img":"https://candidates.democracycl