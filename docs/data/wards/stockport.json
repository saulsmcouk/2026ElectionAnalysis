0,"inc_total":0,"inc_elected":0,"inc_defeated":0,"new_elected":1},{"ward":"Bramhall South & Woodford","seats":1,"turnout_pct":53.5,"results_url":"https://democracy.stockport.gov.uk/mgElectionAreaResults.aspx?ID=866&RPID=237383458","candidates":[{"n":"Dallas Ann Jones","p":"Liberal Democrats","v":2417,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"low","inc":true,"pid":"101524","img":"https://candidates.democracyclub.org.uk/media/images/people/101524/065ba089-0cc7-4255-bd34-f3e7ebc2720f.png","stmt":"Dallas has been a tireless voice for Bramhall, Woodford and parts of Cheadle Hulme, standing up for residents on issues that matter most to our villages. She’s worked closely with local people to resist inappropriate housing developments, protect the countryside around Woodford, and improve road safety across Bramhall. Whether it’s helping to keep our community spaces vibrant or pushing for better infrastructure, Dallas is deeply rooted in the area and always ready to listen to residents’ concerns."},{"n":"Ste Mulvenna","p":"Conservative and Unionist Party","v":2114,"r":2,"e":false,"g":"male","m":"claude","cf":"high","pid":"136400","img":"https://candidates.democracyclub.org.uk/media/images/people/136400/981d39eb-af12-445d-ad21-b98517933358.png"},{"n":"Stephen George Speakman","p":"Reform UK","v":776,"r":3,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"79360"},{"n":"Thomas James Price","p":"Green Party","v":393,"r":4,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"136401"},{"n":"Phil Matley","p":"Labour","v":134,"r":5,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"136399"}],"female_count":0,"male_count":5,"unknown_count":0,"inc_total":1,"inc_elected":1,"inc_defeated":0,"new_elected":0},{"ward":"Bredbury & Woodley","seats":1,"turnout_pct":42.38,"results_url":"https://democracy.stockport.gov.uk/mgElectionAreaResults.aspx?ID=867&RPID=237372095","candidates":[{"n":"Niki Meerman","p":"Liberal Democrats","v":2013,"r":1,"e":true,"g"