unknown_count":0,"inc_total":1,"inc_elected":1,"inc_defeated":0,"new_elected":0},{"ward":"Brinnington & Stockport Central","seats":1,"turnout_pct":28.06,"results_url":"https://democracy.stockport.gov.uk/mgElectionAreaResults.aspx?ID=869&RPID=237372095","candidates":[{"n":"Shaun Regan","p":"Reform UK","v":843,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"high","pid":"136909"},{"n":"Callum Jake Walmsley","p":"Labour","v":784,"r":2,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"112656","img":"https://candidates.democracyclub.org.uk/media/images/people/112656/9b9861e8-fc56-44f1-be84-0cb95ab0417e.png"},{"n":"Eli King","p":"Green Party","v":662,"r":3,"e":false,"g":"male","m":"claude","cf":"high","pid":"136908","img":"https://candidates.democracyclub.org.uk/media/images/people/136908/c689a21d-5809-4670-a299-fc56279d37c0.png"},{"n":"Douglas Greenhalgh","p":"Liberal Democrats","v":297,"r":4,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"112654"},{"n":"Ros Lloyd","p":"Conservative and Unionist Party","v":120,"r":5,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"11028"},{"n":"Adil Shaikh","p":"Trade Unionist and Socialist Coalition","v":32,"r":6,"e":false,"g":"male","m":"claude","cf":"high","pid":"136910"}],"female_count":1,"male_count":5,"unknown_count":0,"inc_total":0,"inc_elected":0,"inc_defeated":0,"new_elected":1},{"ward":"Cheadle East & Cheadle Hulme North","seats":1,"turnout_pct":40.95,"results_url":"https://democracy.stockport.gov.uk/mgElectionAreaResults.aspx?ID=870&RPID=237394443","candidates":[{"n":"Jilly Julian","p":"Liberal Democrats","v":2105,"r":1,"e":true,"g":"female","m":"gender_guesser","cf":"high","inc":true,"pid":"79323","img":"https://candidates.democracyclub.org.uk/media/images/people/79323/541548d3-ed2a-4913-af0d-c0096163291e.png","stmt":"Jilly is a tireless advocate for people in Cheadle East and Cheadle Hulme North. She has championed local schools, community groups and volunteers, helping to bring people together and strengthen community ties. Jilly has also spoken up for residents affected by local flooding and transport changes, ensuring that their views are properly considered. She combines energy, empathy and experience – and she’s passionate about keeping Cheadle and Cheadle Hulme thriving."},{"n":"Stacey Frances Knighton","p":"Reform UK","v":1291,"r":2,"e":false,"g":"female","m":"gender_guesser","cf":"low","pid":"136871"},{"n":"Thomas David Longden","p":"Green Party","v":632,"r":3,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"136872"},{"n":"Yvonne Maureen Guariento","p":"Labour","v":530,"r":4,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"11102"},{"n":"Naveed Ahmad Khan","p":"Conservative and Unionist Party","v":221,"r":5,"e":false,"g":"male","m":"claude","cf":"high","pid":"101554"}],"female_count":3,"male_count":2,"unknown_count":0,"inc_total":1,"inc_elected":1,"inc_defeated":0,"new_elected":0},{"ward":"Cheadle Hulme South","seats":1,"turnout_pct":45.62,"results_url":"https://democracy.stockport.gov.uk/mgElectionAreaResults.aspx?ID=871&RPID=237380115","candidates":[{"n":"Helen Foster-Grime","p":"Liberal Democrats","v":3026,"r":1,"e":true,"g":"female","m":"existing","cf":"high","inc":true,"pid":"41135","img":"https://candidates.democracyclub.org.uk/media/images/images/41135.png","stmt":"Helen has represented Cheadle Hulme South for many years and continues to be one of the most dedicated local voices on Stockport Council. She has fought to protect the character of Cheadle Hulme, supported initiatives to make our neighbourhoods greener and safer, and stood up for families and small businesses. Helen’s deep roots in the community and her track record of delivery make her a trusted and respected councillor who always puts residents first.","tw":"\"helen_fg\""},{"n":"Richard Stuart Bloor","p":"Reform UK","v":1071,"r":2,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"136927"},{"n":"Peter John Atkinson","p":"Green Party","v":544,"r":3,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"112526","stmt":"I’m a Mechanical Engineer, BEng(Hons) Graduate and retired University Senior Lecturer. I’ve lived in Cheadle Hulme for twenty six years and am standing with the Green Party because I believe in social justice, fairness, inclusion and protecting the environment we all share.\n\nIn Cheadle Hulme, my priorities are tackling car pollution, congestion and pavement parking to make streets safer for everyone, especially children walking and cycling to school. I want to extend the Bruntwood Park cycle route and crack down on noise nuisance, including late night car meets near John Lewis and early morning flight curfew violations from Manchester Airport.\n\nI also want to protect and enhance our green spaces, resist the paving over of gardens, and support the biodiversity that makes this area worth living in. Butterflies, hedgehogs, plants and fresh air — that’s the Cheadle Hulme I want to help protect."},{"n":"Daniel Yacoubian","p":"Conservative and Unionist Party","v":492,"r":4,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"136928"},{"n":"Barry Hawkins","p":"Labour","v":274,"r":5,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"92858"}],"female_count":1,"male_count":4,"unknown_count":0,"inc_total":1,"inc_elected":1,"inc_defeated":0,"new_elected":0},{"ward":"Cheadle West & Gatley","seats":1,"turnout_pct":43.14,"results_url":"https://democracy.stockport.gov.uk/mgElectionAreaResults.aspx?ID=872&RPID=237394443","candidates":[{"n":"Ian Hunter","p":"Liberal Democrats","v":2299,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"high","inc":true,"pid":"79387","img":"https://candidates.democracyclub.org.uk/media/images/people/79387/062bbf5a-1be3-4985-9937-4895a6ec7fbc.png","stmt":"Ian is well known for his hands-on approach in Gatley and Cheadle West. From organising litter picks to supporting local shops on Gatley and Cheadle High Streets, he’s a visible and approachable councillor who puts community first. Ian has been at the forefront of efforts to tackle traffic problems and protect local green spaces, while making sure residents’ voices are heard in Stockport Town Hall. He’s passionate about keeping Gatley and Cheadle great places to live and work."},{"n":"Denise Yvonne Fletcher","p":"Reform UK","v":971,"r":2,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"136284"},{"n":"Stephanie Wyatt","p":"Green Party","v":709,"r":3,"e":false,"g":"female","m":"existing","cf":"high","pid":"45945","img":"https://candidates.democracyclub.org.uk/media/images/people/45945/8891a2e8-6213-462d-9c6e-584ede81099a.png"},{"n":"Penny Davis","p":"Conservative and Unionist Party","v":650,"r":4,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"136283"},{"n":"Carl Carrigan","p":"Labour","v":349,"r":5,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"101612"}],"female_count":3,"male_count":2,"unknown_count":0,"inc_total":1,"inc_elected":1,"inc_defeated":0,"new_elected":0},{"ward":"Davenport & Cale Green","seats":1,"turnout_pct":39.65,"results_url":"https://democracy.stockport.gov.uk/mgElectionAreaResults.aspx?ID=873&RPID=237383458","candidates":[{"n":"Alice Delemare","p":"Liberal Democrats","v":1323,"r":1,"e":true,"g":"female","m":"gender_guesser","cf":"high","pid":"116992","img":"https://candidates.democracyclub.org.uk/media/images/people/116992/d150fde2-ab9c-4145-b2e9-3d5dee6c6912.png","stmt":"Alice is a local mum and community campaigner with deep roots in Davenport and Cale Green. She’s been a passionate voice for improving accessibility at Davenport Station, working to ensure that everyone – including parents with prams, older residents and people with disabilities – can use the station safely and easily. Alice is also committed to standing up for local families and small businesses who are feeling the pressure of the cost-of-living crisis. She’s focused on practical solutions to help our community thrive, from supporting local shops to improving public transport and green spaces. Alice brings energy, empathy and a real understanding of local issues – exactly the kind of representative Davenport and Cale Green needs on the council."},{"n":"Wendy Margaret Wild","p":"Labour","v":1081,"r":2,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"11050"},{"n":"Alan Livingstone","p":"Reform UK","v":1063,"r":3,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"136295"},{"n":"Andrew Robert Glassford","p":"Green Party","v":954,"r":4,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"136294"},{"n":"Nathan Lumb","p":"Conservative and Unionist Party","v":191,"r":5,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"101569"},{"n":"Ashley Walker","p":"Your Party","v":54,"r":6,"e":false,"g":"male","m":"existing","cf":"high","pid":"101570","img":"https://candidates.democracyclub.org.uk/media/images/people/101570/cb872f26-f64e-4f39-adcc-a715c80ddc2d.png","stmt":"My name is Ashley Walker and I am a working-class man born on Bridge Hall. I am a socialist and a member of Your Party. I am also a member of several local organisations working to improve rights and living conditions for the people of Stockport.\n\nAs a working-class man who lives in Adswood, I have seen how cuts and the hoarding of wealth by the rich has destroyed, our schools, our health services, our youth services, our communities and so much more.\n\nI am standing for election because I want to see our communities thrive. Whether that’s the communities of the ward I am standing in, and live in, or all the other communities of Stockport.\n\nI know our best hope of building a better future is working together to build a socialist society!\n\nI want to assure you I will always do my best to help you with any issues.\n\nI will respond to emails and messages. I will hold regular surgeries and walk arounds. I will meet with concerned residents as much as I can. \nI will do my best to keep you informed of local matters.\n\nI will always treat people with respect and maintain the highest standards of conduct. If I make a promise I will keep it.","tw":"\"LU_stockport\"","url":"\"https://solidaritypolitics.co.uk/\"","bd":"1993"},{"n":"Tara Louise Hughes","p":"Party Of Women","v":47,"r":7,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"112640","img":"https://candidates.democracyclub.org.uk/media/images/people/112640/5a29f775-2800-490c-b5da-b95cb2bdf5d4.png"}],"female_count":3,"male_count":4,"unknown_count":0,"inc_total":0,"inc_elected":0,"inc_defeated":0,"new_elected":1},{"ward":"Edgeley","seats":1,"turnout_pct":41.7,"results_url":"https://democracy.stockport.gov.uk/mgElectionAreaResults.aspx?ID=874&RPID=237372095","candidates":[{"n":"Jess Meller","p":"Edgeley Community Association","v":1770,"r":1,"e":true,"g":"female","m":"existing","cf":"high","pid":"136946","img":"https://candidates.democracyclub.org.uk/media/images/people/136946/1a9c9c91-3f6f-4620-a353-cb899762ad56.png","stmt":"I’m Jess Meller, and I’m standing as the ECA candidate for Edgeley to help keep the seat for strong, independent local representation.\n\nEdgeley already has two hardworking ECA councillors in Cllrs Wynne and Caton. Together, they’ve shown what focused local representation can achieve — standing up for residents, challenging poor decisions, and pushing for practical improvements. I want to join that team and continue that approach.\n\nThis campaign is about continuing the hard work and determination residents expect: listening to concerns, being visible in the community, and taking action on the issues that matter most — parking pressure, cleaner streets, anti-social behaviour, and protecting Edgeley from overdevelopment.\n\nI believe Edgeley benefits from councillors who focus on the area, not party politics. If elected, I will work closely with Cllrs Wynne and Caton to make sure residents have a strong, consistent voice and that we keep delivering for the community.\n\nIf you see me out in Edgeley, please stop and say hello — I’m keen to hear what matters to you."},{"n":"Peter Marsh","p":"Reform UK","v":731,"r":2,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"136945"},{"n":"Will York","p":"Green Party","v":666,"r":3,"e":false,"g":"male","m":"claude","cf":"high","pid":"136949"},{"n":"Mike Naylor","p":"Labour","v":419,"r":4,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"136947"},{"n":"Robbie Cowbury","p":"Liberal Democrats","v":151,"r":5,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"81193"},{"n":"Stephen Wear","p":"Conservative and Unionist Party","v":88,"r":6,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"136948"}],"female_count":1,"male_count":5,"unknown_count":0,"inc_total":0,"inc_elected":0,"inc_defeated":0,"new_elected":1},{"ward":"Hazel Grove","seats":1,"turnout_pct":43.7,"results_url":"https://democracy.stockport.gov.uk/mgElectionAreaResults.aspx?ID=875&RPID=237372095","candidates":[{"n":"Wendy Meikle","p":"Liberal Democrats","v":1742,"r":1,"e":true,"g":"female","m":"existing","cf":"high","inc":true,"pid":"55390","img":"https://candidates.democracyclub.org.uk/media/images/images/55390-2d37b86f-62ab-47f6-b27d-b4c508cc42dd.png","tw":"\"Wendy4Stockport\""},{"n":"John Howard Kelly","p":"Reform UK","v":1662,"r":2,"e":false,"g":"male","m":"existing","cf":"high","pid":"11075","img":"https://candidates.democracyclub.org.uk/media/images/people/11075/4b4ff287-06fd-49d6-8f09-62c4ddecace5.png"},{"n":"Tim Morley","p":"Conservative and Unionist Party","v":524,"r":3,"e":false,"g":"male","m":"existing","cf":"high","pid":"76960","img":"https://candidates.democracyclub.org.uk/media/images/people/92852/9c05e642-2ec5-4b77-a5d9-d65b35bf919f.png"},{"n":"Dave Shearman","p":"Green Party","v":470,"r":4,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"136434","img":"https://candidates.democracyclub.org.uk/media/images/people/136434/d234582e-adb4-48b1-995a-2b1f200698e5.png"},{"n":"Johnny White","p":"Labour","v":261,"r":5,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"101616"}],"female_count":1,"male_count":4,"unknown_count":0,"inc_total":1,"inc_elected":1,"inc_defeated":0,"new_elected":0},{"ward":"Heald Green","seats":1,"turnout_pct":43.85,"results_url":"https://democracy.stockport.gov.uk/mgElectionElectionAreaResults.aspx?Page=all&EID=70","candidates":[{"n":"Anna Mary Charles-Jones","p":"Independent","v":1780,"r":1,"e":true,"g":"female","m":"existing","cf":"high","inc":true,"pid":"11061","img":"https://candidates.democracyclub.org.uk/media/images/people/11061/9e627c27-2051-452d-a89c-7d122c20a7c1.png","stmt":"Anna has worked as a councillor on issues affecting residents across Heald Green ward, raising local concerns through council work, casework and engagement with residents.\n\nAs a councillor, Anna has\n• Opposed development on the village hall field through the Draft Local Plan process\n• Continued to raise ongoing parking concerns with the council and GM Police\n• Pressed the council to take action over the Beech Tree site, pushing for the owners to tidy the area and make progress on their plans\n• Supported efforts to address long standing anti social behaviour linked to the former Cheadle Royal Nurses Home. The cleared site will provide new housing for Heald Green\n• Supported residents in developing a community initiative which aims to improve access to natural open space for the wider community at Bruckshaw Meadow\n\nIndependent Ratepayer councillors have represented Heald Green ward for many years and must live in the ward to be selected.","url":"\"https://www.healdgreenratepayers.org.uk/\""},{"n":"Nasser Shaikh","p":"Liberal Democrats","v":1372,"r":2,"e":false,"g":"male","m":"existing","cf":"high","pid":"123656","img":"https://candidates.democracyclub.org.uk/media/images/people/123656/3f08d620-f18c-4773-94f7-f1c4229a79e8.png","stmt":"Nasser brings fresh energy, enthusiasm and a deep commitment to Heald Green. As a local resident, he understands the challenges facing the area – from traffic and transport to the need to protect green spaces. Nasser has been active in community and charity work for years, and he’s determined to use that experience to make a real difference for local people. His experience bringing about change in the NHS will prove invaluable to Heald Green. He’s passionate about giving Heald Green residents a strong and effective voice on the council.","url":"\"https://www.cheadle-libdems.org.uk/in-your-community\""},{"n":"Carl Anthony McCabe","p":"Reform UK","v":972,"r":3,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"137186"},{"n":"Emma McCarthy","p":"Green Party","v":434,"r":4,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"137187"},{"n":"Minara Cook","p":"Conservative and Unionist Party","v":222,"r":5,"e":false,"g":"female","m":"claude","cf":"high","pid":"101575","img":"https://candidates.democracyclub.org.uk/media/images/people/101575/46292483-d995-4a93-acdd-821f9cf8af75.png"},{"n":"Kath Priestley","p":"Labour","v":196,"r":6,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"11064"}],"female_count":4,"male_count":2,"unknown_count":0,"inc_total":1,"inc_elected":1,"inc_defeated":0,"new_elected":0},{"ward":"Heatons North","seats":1,"turnout_pct":46.96,"results_url":"https://democracy.stockport.gov.uk/mgElectionAreaResults.aspx?ID=877&RPID=237398415","candidates":[{"n":"Jo Williams","p":"Labour","v":1743,"r":1,"e":true,"g":"female","m":"gender_guesser","cf":"high","pid":"101502"},{"n":"Helena Julia Mellish","p":"Green Party","v":1613,"r":2,"e":false,"g":"female","m":"existing","cf":"high","pid":"11099","img":"https://candidates.democracyclub.org.uk/media/images/people/11099/c78d672b-e5a7-4142-bd5e-be3cd4c38c0f.png","stmt":"My name is Hélèna Mellish and I'm the Green Party's General Election candidate for Stockport, my buzzing home.  I'm proud to represent the Greens as I truly believe they're the only party that has meaningful solutions to today's problems. In light of all the craziness that is going on, they're the only party that stands up for morality and the issues that really matter.   Common sense. Security. Justice. That's what the Green's promise - for our environment, for our economy, and for our people. Green policies are underpinned by core values and rooted in fairness, not the self-interest of a few. We won't be scared into silence and we're ready to take advantage of the incredible opportunity before us: --- the opportunity for a green industrial revolution that energises the economy, whilst protecting our planet and all us people on it. Us folk work hard, we deserve political leadership that works hard for us too! As a small business owner within the food industry, I'm excited to champion local commerce and a transformation of our food systems. We need to take back control of our resources, nationalise essential public services and invest in the technology and infrastructure that will fuel our futures.","tw":"\"Helena_Dugdale\"","li":"\"https://www.linkedin.com/in/helena-j-mellish/\"","bd":"1987"},{"n":"John Dennis Wilson","p":"Reform UK","v":840,"r":3,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"137214"},{"n":"Timothy Cho","p":"Conservative and Unionist Party","v":584,"r":4,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"83657","img":"https://candidates.democracyclub.org.uk/media/images/images/83657-a6da9d3a-7f4c-433c-94ae-b5acd1751e86.png"},{"n":"Alex Hartley","p":"Liberal Democrats","v":409,"r":5,"e":false,"g":"male","m":"ons","cf":"high","pid":"137213"}],"female_count":2,"male_count":3,"unknown_count":0,"inc_total":0,"inc_elected":0,"inc_defeated":0,"new_elected":1},{"ward":"Heatons South","seats":1,"turnout_pct":47.41,"results_url":"https://democracy.stockport.gov.uk/mgElectionElectionAreaResults.aspx?Page=all&EID=70","candidates":[{"n":"Dean Fitzpatrick","p":"Labour","v":2138,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"