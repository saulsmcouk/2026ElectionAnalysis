{"org":"Hastings","wards":[{"ward":"Ashdown","seats":1,"turnout_pct":null,"results_url":"https://hastings.moderngov.co.uk/mgElectionElectionAreaResults.aspx?Page=all&EID=61","candidates":[{"n":"Daniel Kendrick","p":"Reform UK","v":628,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"high","pid":"133443"},{"n":"Marie Louise Parfitt","p":"Green Party","v":407,"r":2,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"133444"},{"n":"Louise Chantal","p":"Labour and Co-operative Party","v":363,"r":3,"e":false,"g":"female","m":"gender_guesser","cf":"high","pid":"133442"},{"n":"Michael Justinian Edwards","p":"Conservative and Unionist Party","v":202,"r":4,"e":false,"g":"male","m":"existing","cf":"high","pid":"42509","img":"https://candidates.democracyclub.org.uk/media/images/people/42509/5325b984-0484-46fe-9a85-479d4f93e624.png"},{"n":"Robert John Wakeford","p":"Liberal Democrats","v":95,"r":5,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"30906"}]},{"ward":"Baird","seats":1,"turnout_pct":null,"results_url":"https://hastings.moderngov.co.uk/mgElectionElectionAreaResults.aspx?Page=all&EID=61","candidates":[{"n":"Will Rumfitt","p":"Green Party","v":492,"r":1,"e":true,"g":"male","m":"claude","cf":"high","pid":"133455"},{"n":"Jack Philip McCree","p":"Reform UK","v":438,"r":2,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"133454","img":"https://candidates.democracyclub.org.uk/media/images/people/133454/b4b4a2e4-58d5-4a06-9f6f-2cb1f85f15d0.png","stmt":"I am a proud Hastings resident and IT support professional for a Managed Service Provider right here in Hastings, bringing practical problem-solving and real-world experience to local decision-making.\n\nMy focuses are, but not limited to, fixing potholes and improving roads across Hastings and East Sussex, listening and responding to the needs of the community of which I hope to serve, protecting valued green spaces, vehemently opposing development on designated green belt land, and ensuring efficient, accountable council services that deliver real value for local people.\n\nI have worked with the Make a Wish foundation and ran a 10k last year which, collectively, raised almost £10,000 for Children with life threatening conditions, ensuring every child has the opportunity to shine.\n\nVote for real change from a real person, vote to fix East Sussex. Vote Reform ➡️"},{"n":"Mike Turner","p":"Independent","v":335,"r":3,"e":false,"g":"male","m":"existing","cf":"high","inc":true,"pid":"45060","img":"https://candidates.democracyclub.org.uk/media/images/people/45060/2d72f0ea-698d-4a48-be88-62ca06b94922.png"},{"n":"Liam Atkins","p":"Conservative and Unionist Party","v":151,"r":4,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"112688"},{"n":"Rick Dillon","p":"Labour Party","v":128,"r":5,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"133453"}]},{"ward":"Braybrooke","seats":1,"turnout_pct":null,"results_url":"https://hastings.moderngov.co.uk/mgElectionElectionAreaResults.aspx?Page=all&EID=61","candidates":[{"n":"Archie Lauchlan","p":"Green Party","v":1232,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"high","pid":"133464"},{"n":"Josh Matthews","p":"Labour Party","v":364,"r":2,"e":false,"g":"male","m":"ons","cf":"high","pid":"112027"},{"n":"Yoong Kam","p":"Reform UK","v":353,"r":3,"e":false,"g":"male","m":"claude","cf":"low","pid":"133463"},{"n":"John Richard Waterfall","p":"Conservative and Unionist Party","v":138,"r":4,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"133465"}]},{"ward":"Castle","seats":1,"turnout_pct":null,"results_url":"https://hastings.moderngov.co.uk/mgElectionElectionAreaResults.aspx?Page=all&EID=61","candidates":[{"n":"Steph Fawbert","p":"Green Party","v":1404,"r":1,"e":true,"g":"male","m":"gender_guesser","cf":"low","pid":"93072"},{"n":"Graeme White","p":"Reform UK","v":336,"r":2,"e":false,"g":"male","m":"gender_guesser","cf":"high","pid":"133472"},{"n":"Judy Rogers","p":"Labour Party","v":33